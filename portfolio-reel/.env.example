# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# ── AI / Media APIs (used client-side via Vite) ──────────────────
VITE_DEEPSEEK_API_KEY=your_deepseek_key_here
VITE_PEXELS_API_KEY=your_pexels_key_here
VITE_PIXABAY_API_KEY=your_pixabay_key_here
VITE_ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ── Render server (Render.com) ────────────────────────────────────
# Set this to your Render.com service URL after deploying render-server/
# Leave empty for local dev (uses the Vite dev server middleware)
VITE_RENDER_SERVER_URL=https://your-app.onrender.com
